# Shared contract — only required fields (+ optional gateway ARN)
# Copy to repo-root .env.shared and fill. Do not commit .env.shared.

# --- AWS ---
AWS_ACCOUNT_ID=
AWS_REGION=us-west-2

# --- Cognito ---
COGNITO_USER_POOL_NAME=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
ENVIRONMENT_CLAIM=dev

# --- AgentCore (optional until gateway exists) ---
AGENTCORE_GATEWAY_ARN=

# --- Dev owners ---
DEV1_NAME=
DEV2_NAME=
