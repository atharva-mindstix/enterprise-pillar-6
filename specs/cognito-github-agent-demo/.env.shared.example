# Shared contract — only required fields (+ optional gateway ARN)
# Copy to repo-root .env.shared and fill. Do not commit .env.shared.

# --- AWS ---
AWS_ACCOUNT_ID=
AWS_REGION=us-west-2

# --- Cognito ---
COGNITO_USER_POOL_NAME=
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
# Only if app client has a secret (needed for USER_PASSWORD_AUTH SECRET_HASH)
COGNITO_APP_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI=http://localhost:8501/

# --- GitHub OAuth App (UI Connect GitHub; callback = GITHUB_REDIRECT_URI) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8501/
GITHUB_OAUTH_SCOPES=read:user repo

# --- AgentCore (JWT / workload; GitHub Identity; gateway) ---
# UI workload for JWT exchange + USER_FEDERATION (must allow AGENTCORE_OAUTH2_RETURN_URL)
AGENTCORE_WORKLOAD_NAME=githubWorkflowUi
AGENTCORE_GITHUB_PROVIDER=pilllar-6-github
AGENTCORE_OAUTH2_RETURN_URL=http://localhost:8501/
# GitHub OAuth App Authorization callback URL (from Outbound Identity provider)
AGENTCORE_GITHUB_CALLBACK_URL=https://bedrock-agentcore.us-west-2.amazonaws.com/identities/oauth2/callback/632c2a61-cbc6-4102-9b1e-17d47f886676
# After agentcore deploy: runtime ARN for Bearer JWT invoke
AGENTCORE_RUNTIME_ARN=
AGENTCORE_GATEWAY_ARN=arn:aws:bedrock-agentcore:us-west-2:003417131700:gateway/bootcamp-gateway-jwodqi3x4j
GATEWAY_BOOTCAMP_GATEWAY_URL=https://bootcamp-gateway-jwodqi3x4j.gateway.bedrock-agentcore.us-west-2.amazonaws.com/mcp

# --- Dev owners ---
DEV1_NAME=
DEV2_NAME=
