# Shared contract for Cognito + GitHub Agent demo
# Copy to .env.shared and fill. Do not commit .env.shared (secrets).
#
#   copy:  specs/cognito-github-agent-demo/.env.shared.example  →  .env.shared  (repo root)

# --- AWS ---
AWS_ACCOUNT_ID=
AWS_REGION=ap-south-1

# --- IAM / S3 (defaults OK) ---
S3_BUCKET_NAME=agent-project-resources
RUNTIME_ROLE_NAME=GitHubAgentRuntimeRole
TASK_ROLE_NAME=GitHubTaskExecutionRole
# Fill after create (optional until deploy):
RUNTIME_ROLE_ARN=
TASK_ROLE_ARN=

# --- Cognito (fill when created) ---
COGNITO_USER_POOL_NAME=agent-demo-users
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_ISSUER=
# Hosted UI domain prefix or full URL (if used)
COGNITO_DOMAIN=

# Demo user
COGNITO_DEMO_USER=priya
COGNITO_DEMO_EMAIL=
# How project/env get into the token: custom_attr | pre_token_lambda | hardcoded_poc
COGNITO_CLAIM_STRATEGY=hardcoded_poc
PROJECT_CLAIM=AgentDemo
ENVIRONMENT_CLAIM=dev

# --- GitHub ---
GITHUB_OWNER=
GITHUB_REPO=agent-demo
GITHUB_OAUTH_CLIENT_ID=
# secret only in .env.shared — never commit
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_ISSUE_LABEL=agent-task

# --- AgentCore / UI ---
AGENTCORE_RUNTIME_NAME=githubWorkflow
# localhost OK for POC
DEMO_UI_URL=http://localhost:3000
GITHUB_OAUTH_CALLBACK_URL=http://localhost:3000/oauth/github/callback

# --- Fixed by spec (do not rename) ---
TOOL_INSPECT=inspect_repository
TOOL_UPDATE_DOCS=update_documentation
TOOL_MODIFY_CODE=modify_source_code
COGNITO_GROUPS=Viewer,DocumentationDeveloper,Developer

# --- Dev owners (optional) ---
DEV1_NAME=
DEV2_NAME=
